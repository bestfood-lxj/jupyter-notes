   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "figure, axes = plt.subplots()\n",
    "Drawing_colored_circle = plt.Circle((0.6,0.6), 0.2)\n",
    "\n",
    "axes.set_aspect(1)\n",
    "\n",
    "axes.add_artist(Drawing_colored_circle)\n",
    "plt.title('Colored Circle')\n",
    "plt.show()"
   ]
